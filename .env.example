DATABASE_URL=postgresql://user:password@localhost:5432/nula_crm
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: force all users into one shared workspace
# NULA_SHARED_WORKSPACE_ID=

# Lead intake webhook (POST /api/webhooks/leads)
# LEAD_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Daily automation cron (GET /api/cron/automations)
# CRON_SECRET=replace-with-a-long-random-secret

# AI provider: openai | anthropic (auto-detects from available API keys if unset)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Campaign email sending (optional — campaigns save as scheduled without this)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=info@nulacrm.ai

# Cloudflare Turnstile CAPTCHA on the public contact form
# NEXT_PUBLIC_TURNSTILE_SITE_KEY is public (client). TURNSTILE_SECRET_KEY is
# server-only — never commit it. Without these set, the CAPTCHA is skipped.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Required for logo uploads via brand import
BLOB_READ_WRITE_TOKEN=

# --- Square billing (subscriptions via Square-hosted checkout) ---
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENV=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Full URL configured in Square for the webhook, e.g. https://www.nulacrm.ai/api/webhooks/square
SQUARE_WEBHOOK_URL=
# Subscription plan VARIATION ids (not the plan id) from the Square catalog
SQUARE_PLAN_PRO_MONTHLY=
SQUARE_PLAN_PRO_ANNUAL=

# Platform super-admins (comma-separated) who can access /dashboard
NULA_SUPERADMIN_EMAILS=
